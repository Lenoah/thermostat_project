// --- 1. Chargement des modules ---
exec("src/plant.sci", -1);
exec("src/controller.sci", -1);
exec("src/sensor.sci", -1);
exec("src/filter.sci", -1);

// --- 2. Paramètres ---
dt = 1; 
t_end = 30 * 60; 
t = 0:dt:t_end;
n = length(t);

// Physique et Thermostat
Text = 18; alpha = 0.035; beta = 0.002;
Tset = 22; h = 1;

// Configuration Capteur
cfg.offset = 0.3;      // Erreur systématique
cfg.sigma = 0.15;      // Bruit blanc
cfg.p_glitch = 0.005;  // 0.5% de chance de glitch
cfg.glitch_amp = 3;    // Amplitude du glitch

// Configuration Filtre
tau = 10; 

// --- 3. Initialisation des vecteurs ---
T_true = zeros(1, n);
T_meas = zeros(1, n);
T_filt = zeros(1, n);
u = zeros(1, n);
glitches = %f * ones(1, n); // Pour le bonus (repérer les glitches)

T_true(1) = 20;
T_meas(1) = 20;
T_filt(1) = 20;
heat_on = %f;

// --- 4. Boucle de Simulation ---
for k = 1:n-1
    // A. Lecture du capteur (salit la réalité)
    [T_meas(k), glitches(k)] = sensor_read(T_true(k), cfg);
    
    // B. Filtrage (nettoie la mesure)
    T_filt(k) = iir_step(T_meas(k), T_filt(k), tau, dt);
    
    // C. Décision (le thermostat regarde la température FILTRÉE)
    [u(k), heat_on] = thermostat_step(T_filt(k), heat_on, Tset, h);
    
    // D. Physique (la pièce réagit au chauffage u)
    T_true(k+1) = plant_step(T_true(k), u(k), Text, dt, alpha, beta);
end


// ==========================================================
// PARTIE D - VISUALISATION (Séance 3)
// ==========================================================

// --- FIGURE 1 : Comparaison et Filtrage ---
scf(1); clf(); 

// 1. Trace la mesure brute (points verts pour visualiser le bruit)
plot(t/60, T_meas, "g.", "MarkerSize", 1); 

// 2. Trace la température réelle (ligne noire, la vérité physique)
plot(t/60, T_true, "k-", "LineWidth", 1); 

// 3. Trace la température filtrée (ligne bleue, vue par le thermostat)
plot(t/60, T_filt, "b-", "LineWidth", 2); 

// 4. Trace les seuils d'hystérésis (lignes rouges pointillées)
plot(t/60, Tlow * ones(1,n), "r--");
plot(t/60, Thigh * ones(1,n), "r--");

// ⭐ BONUS : Marquer les glitches par des croix rouges
idx_glitch = find(glitches == %t);
if ~isempty(idx_glitch) then
    plot(t(idx_glitch)/60, T_meas(idx_glitch), "rx", "MarkerSize", 10);
end

// Configuration Figure 1
title("Figure 1 : Analyse du signal (Réalité vs Mesure vs Filtre)");
xlabel("Temps (minutes)");
ylabel("Température (°C)");
legend(["Mesure brute"; "Réalité (True)"; "Filtrée (IIR)"; "Seuils"; "Glitches"], "lower right");
xgrid();


// --- FIGURE 2 : État du Chauffage ---
scf(2); clf();

// Trace la commande u (0 ou 1)
plot(t/60, u, "r-", "LineWidth", 2);

// Configuration Figure 2
title("Figure 2 : Commande du Chauffage (u)");
xlabel("Temps (minutes)");
ylabel("État (0=OFF, 1=ON)");
// Ajustement des limites pour la lisibilité
gca().data_bounds = [0, -0.1 ; t_end/60, 1.1]; 
xgrid();
